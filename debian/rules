#!/usr/bin/make -f
# The packaged charly binary is prebuilt (copied into the source tree as ./charly by the
# build.yml deb build_template) and installed via debian/opencharly.install. There
# is no compile step, no shared-lib scan, and no strip/dwz on the Go binary.
%:
	dh $@

override_dh_auto_build:
override_dh_auto_test:
override_dh_strip:
override_dh_dwz:
override_dh_shlibdeps:
